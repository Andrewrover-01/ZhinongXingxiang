# Database
DATABASE_URL=sqlite:///./zhinong.db
# For PostgreSQL:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zhinong

# Redis (Phase 4 — caches RAG results; TTL in seconds)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# JWT
SECRET_KEY="eqwsdfghjbfgdfdfdfdfgfgfvfdcfgvbgdcdfvfdcfvfdcfvfdcfvfdcfvfdcfdf"
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# File storage
UPLOAD_DIR=./uploads

# LLM (Phase 2)
# --- Option 1: Alibaba Cloud DashScope / 通义千问 (recommended for China) ---
# QWEN_API_KEY=your-dashscope-api-key-here
# --- Option 2: OpenAI ---
# OPENAI_API_KEY=your-openai-api-key-here
# If neither key is set the system uses a built-in fallback that formats
# retrieved knowledge documents directly (no LLM call).

# ChromaDB (Phase 2)
CHROMA_PERSIST_DIR=./chroma_data

# App
APP_ENV=development
CORS_ORIGINS=["http://localhost:3000"]
