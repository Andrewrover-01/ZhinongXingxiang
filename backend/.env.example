# Database
DATABASE_URL=sqlite:///./zhinong.db
# For PostgreSQL:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zhinong

# Redis (Phase 4 — caches RAG results; TTL in seconds)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# JWT
SECRET_KEY=change-this-to-a-secure-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# File storage
UPLOAD_DIR=./uploads

# LLM (Phase 2)
# OPENAI_API_KEY=sk-xxxxxxxx
# QWEN_API_KEY=xxxxxxxx

# ChromaDB (Phase 2)
CHROMA_PERSIST_DIR=./chroma_data

# App
APP_ENV=development
CORS_ORIGINS=["http://localhost:3000"]
